# LLM
MODEL=gemini/gemini-2.5-flash-lite
GEMINI_API_KEY=your_gemini_api_key
SERPER_API_KEY=your_serper_api_key

# Langtrace (optional, but recommended for job observability)
LANGTRACE_API_KEY=your_langtrace_api_key
# LANGTRACE_SERVICE_NAME=agent-platform
# LANGTRACE_API_HOST=https://langtrace.ai/

# Fallback (Ollama)
# MODEL=ollama/qwen3:8b
# API_BASE=http://127.0.0.1:11434

# GCP & Security
GCP_PROJECT_ID=your-gcp-project-id
CREDENTIAL_SECRET=at_least_32_random_chars

# Pub/Sub (must match backend)
PUBSUB_TOPIC=agent-jobs

# For local development (pull mode)
PUBSUB_LISTEN_MODE=pull
PUBSUB_SUBSCRIPTION=agent-jobs-local
# Skip Firestore `agents` metadata sync on startup in local runs unless needed
AGENT_SYNC_ON_STARTUP=false
