{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/jobs/**", "destination": "/jobs/__ph__.html" },
      { "source": "/agents/**", "destination": "/agents/__ph__.html" }
    ]
  }
}
