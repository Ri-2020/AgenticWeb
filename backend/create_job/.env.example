# GCP project ID
GCP_PROJECT_ID=your-gcp-project-id

# Pub/Sub topic name (must match what the agent subscribes to)
PUBSUB_TOPIC=shopping-agent-jobs

# Secret used to encrypt/decrypt user-provided Gemini API keys (must match agent)
CREDENTIAL_SECRET=at_least_32_random_chars

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Access control settings
DAILY_JOB_LIMIT=3
USER_ACCESS_COLLECTION=user_access
DAILY_USAGE_COLLECTION=user_daily_usage
